#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
SSHD_MATCH_INSTALL="${SCRIPT_DIR}/sshd/match-install.sh"
RUNTIME_INSTALL="${SCRIPT_DIR}/runtime/install.sh"
PACKAGE_COMMAND="ssh-multisession-resume"

operator_command() {
  if [[ -n "${SSH_MULTISESSION_RESUME_COMMAND:-}" ]]; then
    printf '%s\n' "$SSH_MULTISESSION_RESUME_COMMAND"
  elif [[ "$SCRIPT_DIR" == "/usr/lib/${PACKAGE_COMMAND}" ]]; then
    printf '%s\n' "$PACKAGE_COMMAND"
  else
    printf '%s\n' "./${PACKAGE_COMMAND}"
  fi
}

usage() {
  local cmd

  cmd="$(operator_command)"

  cat <<USAGE
Usage:
  ${cmd}                                show status and saved policies
  ${cmd} doctor                         diagnose the current SSH session
  ${cmd} status                         show install + hook status
  ${cmd} sessions                       list managed tmux/screen sessions
  ${cmd} monitor [--interval SECS]      watch managed sessions
  ${cmd} policy show                    list saved per-IP choices
  ${cmd} policy set IP MODE             save a choice (single|multi|skip)
  ${cmd} policy move OLD_IP NEW_IP      move a saved choice to a new IP
  ${cmd} policy forget IP               drop the saved choice for IP
  ${cmd} policy clear                   drop all saved choices
  ${cmd} opt-out                        disable the SSH menu for this user
  ${cmd} opt-in                         re-enable the SSH menu for this user
  ${cmd} detect-current                 print the current SSH client address
  ${cmd} deps                           check or install tmux/screen

Advanced / source-checkout commands:
  ${cmd} apply                          install the per-user shell hook
                                        (the AUR package does this for you)
  ${cmd} rollback                       remove the per-user shell hook + SSHD block
  ${cmd} service-install                install systemd user keepalive
  ${cmd} service-status                 show keepalive unit state
  ${cmd} service-rollback               remove keepalive unit

When installed from the AUR package, no setup is needed. Just open a new SSH
session, pick single / multi / skip in the menu, and your choice is remembered
across reboots.
USAGE
}

die() {
  echo "$*" >&2
  exit 1
}

require_file() {
  local file="$1"

  [[ -r "$file" ]] || die "Missing required file: ${file}"
}

sshd_config_path() {
  printf '%s\n' "${SSHD_CONFIG_FILE:-/etc/ssh/sshd_config}"
}

server_needs_sudo() {
  local config

  config="$(sshd_config_path)"
  [[ "$config" == /etc/* && $EUID -ne 0 ]]
}

run_server() {
  if server_needs_sudo; then
    sudo "$SSHD_MATCH_INSTALL" "$@"
  else
    "$SSHD_MATCH_INSTALL" "$@"
  fi
}

run_server_no_sudo() {
  "$SSHD_MATCH_INSTALL" "$@"
}

target_client_user() {
  if [[ $EUID -eq 0 && -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    printf '%s\n' "$SUDO_USER"
  else
    id -un
  fi
}

target_client_home() {
  local user="$1"
  local home=""

  if [[ "$user" == "$(id -un)" ]]; then
    printf '%s\n' "$HOME"
    return 0
  fi

  if command -v getent >/dev/null 2>&1; then
    home="$(getent passwd "$user" | cut -d: -f6 || true)"
  fi

  [[ -n "$home" ]] || die "Could not determine home directory for ${user}."
  printf '%s\n' "$home"
}

run_client() {
  local user home

  user="$(target_client_user)"
  home="$(target_client_home "$user")"

  if [[ "$user" != "$(id -un)" ]]; then
    sudo -u "$user" env HOME="$home" "$RUNTIME_INSTALL" "$@"
  else
    HOME="$home" "$RUNTIME_INSTALL" "$@"
  fi
}

prompt_yes_no() {
  local prompt="$1"
  local answer=""
  local key=""
  local rest=""
  local selected=0
  local yellow=$'\033[1;33m'
  local white=$'\033[0;37m'
  local reset=$'\033[0m'

  if [[ -t 0 && -t 1 ]]; then
    while true; do
      if (( selected == 0 )); then
        printf '\r%s %s[ YES ]%s %s[ NO ]%s\033[K' "$prompt" "$yellow" "$reset" "$white" "$reset"
      else
        printf '\r%s %s[ YES ]%s %s[ NO ]%s\033[K' "$prompt" "$white" "$reset" "$yellow" "$reset"
      fi

      IFS= read -r -s -n 1 key || {
        printf '\n'
        return 1
      }

      case "$key" in
        ''|$'\n'|$'\r')
          printf '\n'
          (( selected == 0 ))
          return $?
          ;;
        $'\e')
          rest=""
          IFS= read -r -s -n 2 -t 0.1 rest || true
          case "$rest" in
            '[C'|'[B')
              selected=1
              ;;
            '[D'|'[A')
              selected=0
              ;;
          esac
          ;;
        ' '|$'\t')
          if (( selected == 0 )); then
            selected=1
          else
            selected=0
          fi
          ;;
        y|Y)
          printf '\n'
          return 0
          ;;
        n|N)
          printf '\n'
          return 1
          ;;
      esac
    done
  fi

  while true; do
    printf '%s %s[ YES ]%s %s[ NO ]%s: ' "$prompt" "$yellow" "$reset" "$white" "$reset"
    if ! IFS= read -r answer; then
      echo
      return 1
    fi

    case "${answer,,}" in
      ""|y|yes)
        return 0
        ;;
      n|no)
        return 1
        ;;
      *)
        echo "Please answer YES or NO."
        ;;
    esac
  done
}

prompt_self_add() {
  local ip="$1"

  prompt_yes_no "Self add current SSH client IP (${ip})?"
}

detect_current_ip() {
  "$SSHD_MATCH_INSTALL" detect-current
}

package_manager() {
  if command -v pacman >/dev/null 2>&1; then
    printf '%s\n' pacman
  elif command -v apt-get >/dev/null 2>&1; then
    printf '%s\n' apt-get
  elif command -v dnf >/dev/null 2>&1; then
    printf '%s\n' dnf
  elif command -v yum >/dev/null 2>&1; then
    printf '%s\n' yum
  elif command -v zypper >/dev/null 2>&1; then
    printf '%s\n' zypper
  elif command -v apk >/dev/null 2>&1; then
    printf '%s\n' apk
  else
    return 1
  fi
}

run_as_root() {
  if [[ $EUID -eq 0 ]]; then
    "$@"
  else
    command -v sudo >/dev/null 2>&1 || die "sudo is required to install dependencies."
    sudo "$@"
  fi
}

missing_dependency_packages() {
  if ! command -v tmux >/dev/null 2>&1; then
    printf '%s\n' tmux
  fi

  if ! command -v tmux >/dev/null 2>&1 && ! command -v screen >/dev/null 2>&1; then
    printf '%s\n' screen
  fi
}

install_packages() {
  local manager="$1"
  shift

  [[ $# -gt 0 ]] || return 0

  case "$manager" in
    pacman)
      run_as_root pacman -S --needed --noconfirm "$@"
      ;;
    apt-get)
      run_as_root apt-get update
      run_as_root apt-get install -y "$@"
      ;;
    dnf)
      run_as_root dnf install -y "$@"
      ;;
    yum)
      run_as_root yum install -y "$@"
      ;;
    zypper)
      run_as_root zypper install -y "$@"
      ;;
    apk)
      run_as_root apk add "$@"
      ;;
    *)
      die "Unsupported package manager: ${manager}"
      ;;
  esac
}

cmd_deps() {
  local manager=""
  local -a packages=()

  while IFS= read -r package; do
    [[ -n "$package" ]] && packages+=("$package")
  done < <(missing_dependency_packages)

  if command -v tmux >/dev/null 2>&1; then
    echo "tmux: present"
  else
    echo "tmux: missing"
  fi

  if command -v screen >/dev/null 2>&1; then
    echo "screen fallback: present"
  else
    echo "screen fallback: missing"
  fi

  if [[ ${#packages[@]} -eq 0 ]]; then
    echo "dependencies: ok"
    return 0
  fi

  if ! manager="$(package_manager)"; then
    die "Could not find a supported package manager. Install: ${packages[*]}"
  fi

  echo "package manager: ${manager}"
  echo "missing packages: ${packages[*]}"
  if prompt_yes_no "Install missing packages (${packages[*]})?"; then
    install_packages "$manager" "${packages[@]}"
    echo "Dependency install complete."
  else
    die "Missing dependency install declined."
  fi
}

ensure_mux_available() {
  if command -v tmux >/dev/null 2>&1 || command -v screen >/dev/null 2>&1; then
    return 0
  fi

  echo "tmux or screen is required for managed SSH sessions."
  cmd_deps
}

maybe_offer_service_install() {
  if [[ ! -t 0 || ! -t 1 ]]; then
    return 0
  fi

  command -v tmux >/dev/null 2>&1 || return 0
  command -v systemctl >/dev/null 2>&1 || return 0

  if prompt_yes_no "Install user service for cross-boot tmux readiness?"; then
    run_client service-install
  else
    echo "Skipped user service install."
  fi
}

cmd_apply() {
  local current_ip=""

  require_file "$SSHD_MATCH_INSTALL"
  require_file "$RUNTIME_INSTALL"

  ensure_mux_available

  if ! current_ip="$(detect_current_ip)"; then
    die "Could not detect the current SSH client IP. Run this from the SSH session you want to manage."
  fi

  if ! prompt_self_add "$current_ip"; then
    echo "No changes made."
    return 0
  fi

  run_server add-current --ip "$current_ip"
  run_client apply
  maybe_offer_service_install

  echo
  echo "Install complete. Log out and reconnect from this SSH client."
  echo "After reconnecting, run $(operator_command) doctor to verify the active session."
}

cmd_status() {
  require_file "$SSHD_MATCH_INSTALL"
  require_file "$RUNTIME_INSTALL"

  echo "Server:"
  run_server_no_sudo status
  echo
  echo "Client:"
  run_client status
}

cmd_sessions() {
  require_file "$RUNTIME_INSTALL"

  run_client sessions
}

cmd_monitor() {
  local interval=2

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --interval)
        [[ $# -ge 2 && "${2:-}" != --* ]] || die "Missing value for --interval"
        interval="$2"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        die "Unknown monitor arg: $1"
        ;;
    esac
  done

  [[ "$interval" =~ ^[0-9]+$ && "$interval" -gt 0 ]] || die "Invalid monitor interval: ${interval}"

  while true; do
    printf '\033[H\033[2J'
    date
    echo
    cmd_sessions
    sleep "$interval"
  done
}

cmd_service_install() {
  require_file "$RUNTIME_INSTALL"

  run_client service-install
}

cmd_service_status() {
  require_file "$RUNTIME_INSTALL"

  run_client service-status
}

cmd_service_rollback() {
  require_file "$RUNTIME_INSTALL"

  run_client service-rollback
}

cmd_doctor() {
  local current_ip=""
  local session_name=""
  local ok=1
  local in_managed_mux=0

  require_file "$SSHD_MATCH_INSTALL"
  require_file "$RUNTIME_INSTALL"

  echo "Session:"
  if [[ -n "${SSH_CONNECTION:-}${SSH_CLIENT:-}${SSH_TTY:-}" ]]; then
    echo "  ssh: yes"
  else
    echo "  ssh: no"
    ok=0
  fi

  if current_ip="$(detect_current_ip 2>/dev/null)"; then
    echo "  current client ip: ${current_ip}"
  else
    echo "  current client ip: not detected"
    ok=0
  fi

  if [[ "${SSH_AUTO_RESUME:-}" == "1" || "${SCREEN_KILL_ON_HANGUP:-}" == "1" ]]; then
    echo "  sshd match env: yes"
  else
    echo "  sshd match env: no"
    ok=0
  fi

  if [[ -n "${TMUX:-}" ]]; then
    session_name="$(tmux display-message -p '#S' 2>/dev/null || true)"
    [[ -n "$session_name" ]] || session_name="${TMUX}"
    echo "  inside tmux: yes (${session_name})"
    case "$TMUX" in
      */ssh-resume-*)
        echo "  managed tmux: yes"
        in_managed_mux=1
        ;;
      *)
        echo "  managed tmux: unknown"
        ;;
    esac
  else
    echo "  inside tmux: no"
  fi

  if [[ -n "${STY:-}" ]]; then
    echo "  inside screen: yes (${STY})"
    case "$STY" in
      *.ssh-resume-*|ssh-resume-*|*.ssh-kill-*|ssh-kill-*|*.ip-*|ip-*)
        echo "  managed screen: yes"
        in_managed_mux=1
        ;;
      *)
        echo "  managed screen: unknown"
        ;;
    esac
  else
    echo "  inside screen: no"
  fi

  if (( in_managed_mux == 0 )); then
    ok=0
  fi

  echo
  echo "Client hook:"
  run_client status

  echo
  echo "Multiplexer sessions:"
  run_client sessions

  echo
  if (( ok == 1 )); then
    [[ -n "$session_name" ]] || session_name="${STY:-managed session}"
    echo "doctor: ok (${session_name})"
    echo "Disconnecting this SSH client should leave programs running for the next reconnect."
  else
    echo "doctor: not active for this login"
    echo "If you just installed it, log out completely and reconnect from the matched SSH client."
    return 1
  fi
}

policy_dir() {
  local user home
  user="$(target_client_user)"
  home="$(target_client_home "$user")"
  printf '%s\n' "${XDG_CONFIG_HOME:-${home}/.config}/ssh-multisession-resume"
}

policy_choices_dir() {
  printf '%s/choices\n' "$(policy_dir)"
}

policy_optout_path() {
  printf '%s/opt-out\n' "$(policy_dir)"
}

sanitize_ip_for_path() {
  printf '%s' "$1" | tr -c 'A-Za-z0-9_-' '_'
}

valid_policy_mode() {
  case "$1" in
    single|multi|skip) return 0 ;;
    *) return 1 ;;
  esac
}

policy_show() {
  local dir
  dir="$(policy_choices_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "(no saved policies)" 2>/dev/null || true
    return 0
  fi

  local found=0
  local entry mode name
  while IFS= read -r -d '' entry; do
    name="$(basename "$entry")"
    mode="$(head -n 1 "$entry" 2>/dev/null || true)"
    [[ -n "$mode" ]] || mode="(empty)"
    # Tolerate broken-pipe writes (`policy show | head`, `... | grep -q`).
    printf '  %s -> %s\n' "$name" "$mode" 2>/dev/null || return 0
    found=1
  done < <(find "$dir" -maxdepth 1 -type f -print0 2>/dev/null)

  if [[ "$found" -eq 0 ]]; then
    echo "(no saved policies)" 2>/dev/null || true
  fi
}

cmd_policy() {
  local sub="${1:-show}"
  [[ $# -gt 0 ]] && shift

  case "$sub" in
    show|list)
      policy_show
      ;;
    set)
      local ip="${1:-}" mode="${2:-}"
      [[ -n "$ip" && -n "$mode" ]] || die "Usage: $(operator_command) policy set IP single|multi|skip"
      valid_policy_mode "$mode" || die "Invalid mode: ${mode} (use single, multi, or skip)"
      local safe choices_dir
      safe="$(sanitize_ip_for_path "$ip")"
      [[ -n "$safe" ]] || die "Empty IP after sanitization."
      choices_dir="$(policy_choices_dir)"
      mkdir -p "$choices_dir"
      chmod 700 "$(policy_dir)" 2>/dev/null || true
      printf '%s\n' "$mode" > "${choices_dir}/${safe}"
      echo "Saved policy: ${safe} -> ${mode}"
      ;;
    move|mv|rename|switch)
      local old_ip="${1:-}" new_ip="${2:-}"
      [[ -n "$old_ip" && -n "$new_ip" ]] || die "Usage: $(operator_command) policy move OLD_IP NEW_IP"
      local old_safe new_safe choices_dir
      old_safe="$(sanitize_ip_for_path "$old_ip")"
      new_safe="$(sanitize_ip_for_path "$new_ip")"
      [[ -n "$old_safe" && -n "$new_safe" ]] || die "Empty IP after sanitization."
      choices_dir="$(policy_choices_dir)"
      [[ -f "${choices_dir}/${old_safe}" ]] || die "No saved policy for: ${old_safe}"
      mkdir -p "$choices_dir"
      chmod 700 "$(policy_dir)" 2>/dev/null || true
      mv -f "${choices_dir}/${old_safe}" "${choices_dir}/${new_safe}"
      echo "Moved policy: ${old_safe} -> ${new_safe}"
      ;;
    forget|drop|delete|rm)
      local ip="${1:-}"
      [[ -n "$ip" ]] || die "Usage: $(operator_command) policy forget IP"
      local safe choices_dir
      safe="$(sanitize_ip_for_path "$ip")"
      [[ -n "$safe" ]] || die "Empty IP after sanitization."
      choices_dir="$(policy_choices_dir)"
      if [[ -f "${choices_dir}/${safe}" ]]; then
        rm -f "${choices_dir}/${safe}"
        echo "Forgot policy: ${safe}"
      else
        echo "No saved policy for: ${safe}"
      fi
      ;;
    clear|reset)
      local choices_dir
      choices_dir="$(policy_choices_dir)"
      if [[ -d "$choices_dir" ]]; then
        find "$choices_dir" -maxdepth 1 -type f -delete 2>/dev/null || true
        echo "Cleared all saved policies."
      else
        echo "(no saved policies)"
      fi
      ;;
    -h|--help)
      usage
      ;;
    *)
      die "Unknown policy subcommand: ${sub}"
      ;;
  esac
}

cmd_opt_out() {
  local dir path
  dir="$(policy_dir)"
  path="$(policy_optout_path)"
  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true
  : > "$path"
  echo "Opt-out marker written: ${path}"
  echo "New SSH sessions for this user will skip the auto-resume menu."
}

cmd_opt_in() {
  local path
  path="$(policy_optout_path)"
  if [[ -f "$path" ]]; then
    rm -f "$path"
    echo "Removed opt-out marker: ${path}"
  else
    echo "No opt-out marker found at ${path} (already opted in)."
  fi
}

cmd_summary() {
  require_file "$SSHD_MATCH_INSTALL"
  require_file "$RUNTIME_INSTALL"

  local hook_path="/etc/profile.d/ssh-multisession-resume.sh"
  echo "Install:"
  if [[ -r "$hook_path" ]]; then
    echo "  system hook: ${hook_path} (installed)"
  else
    echo "  system hook: not installed at ${hook_path}"
    echo "                (install the AUR package, or run \`$(operator_command) apply\` for"
    echo "                 a per-user shell hook from a source checkout)"
  fi

  if command -v tmux >/dev/null 2>&1; then
    echo "  tmux: present"
  else
    echo "  tmux: missing"
  fi
  if command -v screen >/dev/null 2>&1; then
    echo "  screen: present"
  else
    echo "  screen: missing"
  fi

  echo
  echo "This session:"
  if [[ -n "${SSH_CONNECTION:-}${SSH_CLIENT:-}${SSH_TTY:-}" ]]; then
    local ip=""
    ip="$(detect_current_ip 2>/dev/null || true)"
    echo "  ssh: yes${ip:+ (from ${ip})}"
  else
    echo "  ssh: no"
  fi
  if [[ -n "${TMUX:-}" ]]; then
    local sname=""
    sname="$(tmux display-message -p '#S' 2>/dev/null || true)"
    echo "  inside tmux: yes${sname:+ (${sname})}"
  fi
  if [[ -n "${STY:-}" ]]; then
    echo "  inside screen: yes (${STY})"
  fi

  echo
  echo "Saved policies:"
  policy_show

  local optout
  optout="$(policy_optout_path)"
  if [[ -f "$optout" ]]; then
    echo
    echo "Opt-out marker present at ${optout}"
    echo "Remove with: $(operator_command) opt-in"
  fi

  echo
  echo "Next steps:"
  if [[ -r "$hook_path" ]]; then
    echo "  Just SSH in from a new client. The menu will appear on first connect"
    echo "  and your choice will be remembered. Run \`$(operator_command) doctor\`"
    echo "  inside the SSH session to verify it landed in a managed tmux session."
  else
    echo "  Install the AUR package, or run \`$(operator_command) apply\` from this"
    echo "  source checkout to install a per-user shell hook."
  fi
}

cmd_rollback() {
  require_file "$SSHD_MATCH_INSTALL"
  require_file "$RUNTIME_INSTALL"

  run_server rollback
  run_client service-rollback
  run_client rollback
}

ACTION="${1:-summary}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$ACTION" in
  summary)
    cmd_summary "$@"
    ;;
  apply)
    cmd_apply "$@"
    ;;
  doctor)
    cmd_doctor "$@"
    ;;
  status)
    cmd_status "$@"
    ;;
  sessions)
    cmd_sessions "$@"
    ;;
  monitor)
    cmd_monitor "$@"
    ;;
  deps)
    cmd_deps "$@"
    ;;
  policy)
    cmd_policy "$@"
    ;;
  opt-out)
    cmd_opt_out "$@"
    ;;
  opt-in)
    cmd_opt_in "$@"
    ;;
  service-install)
    cmd_service_install "$@"
    ;;
  service-status)
    cmd_service_status "$@"
    ;;
  service-rollback)
    cmd_service_rollback "$@"
    ;;
  rollback)
    cmd_rollback "$@"
    ;;
  detect-current)
    detect_current_ip "$@"
    ;;
  -h|--help)
    usage
    ;;
  *)
    echo "Unknown action: ${ACTION}" >&2
    usage >&2
    exit 2
    ;;
esac
